# Core server configuration
NODE_ENV=development
DATABASE_URL=file:local.db
CORS_ORIGIN=http://localhost:3001

# Better Auth
# Generate a real local secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# OpenAI
# Required once the Agents SDK and vector store integrations are wired.
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=

# Braintrust
# Required once eval runs are wired.
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_NAME=openai-demo-bi-metrics-copilot

# Databricks
# Leave mock mode enabled until you are ready to query a real SQL Warehouse.
USE_MOCK_DATABRICKS=true
ENABLE_DATABRICKS_EXECUTION=false
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=bi_demo
