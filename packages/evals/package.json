{
  "name": "@openai-demo/evals",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "eval:local": "bun run src/run-local.ts",
    "eval:local:model": "bun run src/run-model-local.ts",
    "eval:braintrust": "bun run src/cloud-cost.eval.ts",
    "eval:braintrust:model": "bun run src/cloud-cost-model.eval.ts"
  },
  "dependencies": {
    "@openai-demo/agents": "workspace:*",
    "@openai-demo/databricks": "workspace:*",
    "@openai-demo/rag": "workspace:*",
    "braintrust": "^3.17.0",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@openai-demo/config": "workspace:*",
    "typescript": "catalog:"
  }
}
